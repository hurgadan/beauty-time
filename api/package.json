{
  "name": "beauty-time-api",
  "version": "0.1.0",
  "private": true,
  "description": "Beauty-Time API (NestJS + TypeORM)",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:e2e:up": "docker compose -f docker-compose.e2e.yml up -d --wait",
    "test:e2e:down": "docker compose -f docker-compose.e2e.yml down -v",
    "test:e2e:run": "jest --config ./test/e2e/config/jest-e2e.json --runInBand",
    "test:e2e": "sh -c \"npm run test:e2e:up && npm run test:e2e:run; CODE=$?; npm run test:e2e:down; exit $CODE\"",
    "typeorm:migration:run": "typeorm migration:run -d database/data-source.js",
    "typeorm:migration:revert": "typeorm migration:revert -d database/data-source.js",
    "typeorm:migration:show": "typeorm migration:show -d database/data-source.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.3",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.44.1",
    "typescript": "^5.7.2"
  }
}
